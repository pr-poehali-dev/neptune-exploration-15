{
  "tests": [
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Access without token",
      "method": "GET",
      "path": "/?action=users",
      "expectedStatus": 403,
      "expectedBody": {"error": "Доступ запрещён"},
      "bodyMatcher": "partial"
    }
  ]
}
