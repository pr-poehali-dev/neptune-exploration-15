{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/?action=register",
      "body": {"nickname": "test_player", "login": "testuser", "password": "secret123", "age": 18},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with correct credentials",
      "method": "POST",
      "path": "/?action=login",
      "body": {"login": "testuser", "password": "secret123"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"login": "testuser", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный логин или пароль"},
      "bodyMatcher": "partial"
    }
  ]
}
